# Copy to .env and adjust. Never commit the real .env.

# SQLite for local dev; swap for postgresql+asyncpg://user:pass@host/db in prod.
DATABASE_URL=sqlite+aiosqlite:///./sentinel.db

# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60

ENVIRONMENT=development
DEBUG=true

# Background rule engine: evaluates alarm rules every ENGINE_INTERVAL seconds.
ENGINE_ENABLED=true
ENGINE_INTERVAL=30

# Simulated collector/executor: walks metrics and applies pending actions.
# Turn off when a real on-VM agent feeds the API.
SIMULATOR_ENABLED=true
SIMULATOR_INTERVAL=5

# Comma-separated list of allowed browser origins.
CORS_ORIGINS=http://localhost:5173
